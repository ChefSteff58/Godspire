# Supabase — powers the global leaderboard (wired up in Milestone 7).
# NOT required for local dev or the early milestones.
# Copy this file to .env.local and fill in your project's values.
# Only VITE_-prefixed vars are exposed to the client; the anon key is safe to ship (gated by RLS).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
